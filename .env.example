# Database (PostgreSQL) — leave blank to use in-memory store
DATABASE_URL=postgresql://user:password@localhost:5432/nightwave

# Server
PORT=3001
NODE_ENV=development

# Frontend (set for production build)
VITE_API_URL=http://localhost:3001

# YouTube Data API (optional, for future search integration)
YOUTUBE_API_KEY=

# Auth secret (for future JWT/session auth)
AUTH_SECRET=change-me-to-a-random-string

# ============================================================
# Enrichment Pipeline Configuration
# ============================================================

# Background scheduler interval (ms). Default: 180000 (3 minutes)
ENRICH_INTERVAL_MS=180000

# Tracks to process per scheduler tick. Default: 2
ENRICH_BATCH_SIZE=2

# Max concurrent enrichment jobs. Default: 2
ENRICH_MAX_CONCURRENCY=2

# AI budget guardrails (Stage B)
ENRICH_MAX_AI_PER_HOUR=10
ENRICH_MAX_AI_PER_DAY=50

# Disable background scheduler entirely. Default: false
ENRICH_SCHEDULER_DISABLED=false

# OpenAI API key — required for Stage B (AI deep enrichment)
# Leave blank to run Stage A (YouTube + parsing) only
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Last.fm API key (optional, future provider)
LASTFM_API_KEY=

# yt-dlp path (if not in PATH)
YT_DLP_PATH=yt-dlp
