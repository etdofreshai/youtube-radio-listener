# Database (PostgreSQL) — leave blank to use in-memory store
DATABASE_URL=postgresql://user:password@localhost:5432/nightwave

# Server
PORT=3001
NODE_ENV=development

# Frontend (set for production build)
VITE_API_URL=http://localhost:3001

# YouTube Data API (optional, for future search integration)
YOUTUBE_API_KEY=

# Auth secret (for future JWT/session auth)
AUTH_SECRET=change-me-to-a-random-string

# App password gate — protects the frontend from unauthorized access.
# If this variable is NOT set (or is empty), the gate is bypassed entirely
# (dev-friendly mode). Set it to any string to require a password on load.
# Example: APP_PASSWORD=mysecret
APP_PASSWORD=

# ============================================================
# Enrichment Pipeline Configuration
# ============================================================

# Background scheduler interval (ms). Default: 180000 (3 minutes)
ENRICH_INTERVAL_MS=180000

# Tracks to process per scheduler tick. Default: 2
ENRICH_BATCH_SIZE=2

# Max concurrent enrichment jobs. Default: 2
ENRICH_MAX_CONCURRENCY=2

# AI budget guardrails (Stage B)
ENRICH_MAX_AI_PER_HOUR=10
ENRICH_MAX_AI_PER_DAY=50

# Disable background scheduler entirely. Default: false
ENRICH_SCHEDULER_DISABLED=false

# OpenAI API key — required for Stage B (AI deep enrichment)
# Leave blank to run Stage A (YouTube + parsing) only
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Last.fm API key (optional, future provider)
LASTFM_API_KEY=

# yt-dlp path (if not in PATH)
YT_DLP_PATH=yt-dlp

# ============================================================
# Song Explorations / Recommendation Engine Configuration
# ============================================================

# Mode: 'dry-run' (mock adapter) or 'live' (real YouTube API)
SONG_EXPLORATIONS_MODE=dry-run

# YouTube API key for discovery (optional, uses mock in dry-run)
SONG_EXPLORATIONS_YOUTUBE_API_KEY=

# Data directory for song exploration state
SONG_EXPLORATIONS_DATA_DIR=./data/song-explorations

# Discovery interval in minutes. Default: 60 (hourly)
SONG_EXPLORATIONS_DISCOVERY_INTERVAL_MINUTES=60

# Maximum tracks to import per hour. Default: 5
SONG_EXPLORATIONS_HOURLY_IMPORT_CAP=5

# Minimum confidence score (0-1) to accept a candidate. Default: 0.5
SONG_EXPLORATIONS_MIN_CONFIDENCE_SCORE=0.5

# Duration bounds for candidates (seconds)
SONG_EXPLORATIONS_MIN_DURATION_SECONDS=90
SONG_EXPLORATIONS_MAX_DURATION_SECONDS=600

# Log level: debug, info, warn, error
SONG_EXPLORATIONS_LOG_LEVEL=info

# ============================================================
# AI Recommendations (Cloud Agent SDK)
# ============================================================

# Enable/disable AI-powered recommendations. Default: true
RECOMMENDATION_ENABLED=true

# How often to run recommendation discovery (minutes). Default: 60 (hourly)
RECOMMENDATION_INTERVAL_MINUTES=60

# Maximum tracks to add per recommendation run. Default: 5
RECOMMENDATION_ADD_PER_RUN=5

# Cloud Agent SDK OAuth token (required for live mode)
# This token authenticates requests to the AI recommendation service
CLOUD_AGENT_OAUTH_TOKEN=

# AI model for recommendations. Default: gpt-4o
RECOMMENDATION_MODEL=gpt-4o

# Cloud Agent SDK API endpoint
CLOUD_AGENT_ENDPOINT=https://api.openai.com/v1/chat/completions
