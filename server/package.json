{
  "name": "nightwave-server",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "song:explore": "tsx src/song-explorations/index.ts",
    "song:discover": "tsx src/song-explorations/index.ts discover",
    "song:import": "tsx src/song-explorations/index.ts import",
    "song:status": "tsx src/song-explorations/index.ts status",
    "song:cron": "tsx src/song-explorations/index.ts cron",
    "test": "node --import tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "pg": "^8.19.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.19.13",
    "@types/pg": "^8.16.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3"
  }
}
