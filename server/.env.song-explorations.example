# song-explorations configuration (namespaced for youtube-radio-listener server)

# YouTube Data API key (not needed for dry-run mode)
SONG_EXPLORATIONS_YOUTUBE_API_KEY=

# Mode: "dry-run" uses mock data, "live" hits real YouTube API
SONG_EXPLORATIONS_MODE=dry-run

# Data directory for persistent state (tracks, candidates, seen set)
SONG_EXPLORATIONS_DATA_DIR=./data/song-explorations

# Discovery settings
SONG_EXPLORATIONS_DISCOVERY_INTERVAL_MINUTES=20
SONG_EXPLORATIONS_HOURLY_IMPORT_CAP=20

# Scoring thresholds
SONG_EXPLORATIONS_MIN_CONFIDENCE_SCORE=0.5
SONG_EXPLORATIONS_MIN_DURATION_SECONDS=90
SONG_EXPLORATIONS_MAX_DURATION_SECONDS=600

# Logging level: debug | info | warn | error
SONG_EXPLORATIONS_LOG_LEVEL=info
